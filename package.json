{
  "name": "clarif-ai",
  "displayName": "ClarifAI",
  "description": "AI code explainer supporting Ollama and OpenAI-compatible APIs",
  "version": "0.1.0",
  "publisher": "AbdulkaderSafi",
  "author": {
    "name": "Safi",
    "email": "safi.abdulkader@gmail.com",
    "url": "https://abdulkadersafi.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Abdulkader-Safi/clarifai.git"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "keywords": [
    "code explanation",
    "ollama",
    "ollama claud",
    "ai",
    "code assistant",
    "llm",
    "local ai",
    "code analysis",
    "developer tools",
    "openai",
    "openai-compatible"
  ],
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Education"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "icon": "./media/image.png",
  "contributes": {
    "commands": [
      {
        "command": "ollamaExplainer.explainCode",
        "title": "Explain Code with ClarifAI",
        "icon": "$(hubot)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "clarifai-explainer",
          "title": "ClarifAI",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "clarifai-explainer": [
        {
          "type": "webview",
          "id": "ollamaExplainer",
          "name": "Code Explainer",
          "icon": "$(hubot)"
        }
      ]
    },
    "configuration": {
      "title": "ClarifAI",
      "properties": {
        "clarifai.customProviders": {
          "type": "array",
          "default": [],
          "description": "Custom OpenAI-compatible LLM providers",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "baseUrl": {
                "type": "string"
              },
              "model": {
                "type": "string"
              },
              "providerType": {
                "type": "string",
                "enum": [
                  "ollama",
                  "openai-compatible"
                ]
              },
              "requiresApiKey": {
                "type": "boolean"
              }
            }
          }
        },
        "clarifai.selectedProvider": {
          "type": "string",
          "default": "",
          "description": "ID of the currently selected provider"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.18.12",
    "@types/vscode": "^1.105.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.36.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "ollama": "^0.6.0",
    "openai": "^4.89.0"
  }
}